{
  "name": "lorcana-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web board viewer for the Lorcana engine (Svelte + WASM).",
  "scripts": {
    "wasm": "bash ../scripts/build-wasm.sh",
    "dev": "vite",
    "build": "npm run wasm && svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . && stylelint \"src/**/*.{css,svelte}\" && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/svelte": "^5.2.0",
    "@tsconfig/svelte": "^5.0.0",
    "@types/node": "^22.19.19",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "postcss-html": "^1.7.0",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^3.3.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
